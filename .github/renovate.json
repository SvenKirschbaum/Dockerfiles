{
  "extends": [
    "github>fallobst22/renovate-config"
  ],
  "pip_requirements": {
    "managerFilePatterns": [
      "/^paperless\\/constraints\\.txt$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^smtprelay\\/Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+ARG SMTPRELAY_VERSION=(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "keycloak/**"
      ],
      "labels": [
        "keycloak"
      ],
      "additionalBranchPrefix": "keycloak-"
    },
    {
      "matchFileNames": [
        "nginx-static/**"
      ],
      "labels": [
        "nginx-static"
      ],
      "additionalBranchPrefix": "nginx-static-"
    },
    {
      "matchFileNames": [
        "paperless/**"
      ],
      "labels": [
        "paperless"
      ],
      "additionalBranchPrefix": "paperless-"
    },
    {
      "matchFileNames": [
        "smtprelay/**"
      ],
      "labels": [
        "smtprelay"
      ],
      "additionalBranchPrefix": "smtprelay-"
    },
    {
      "matchFileNames": [
        "teamcity-agent/**"
      ],
      "labels": [
        "teamcity-agent"
      ],
      "additionalBranchPrefix": "teamcity-agent-"
    },
    {
      "matchFileNames": [
        "openclaw/**",
        "openclaw-node/**"
      ],
      "labels": [
        "openclaw"
      ],
      "additionalBranchPrefix": "openclaw-"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "jetbrains/teamcity-agent"
      ],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)(?:\\.(?<patch>\\d+))?(?:-(?<compatibility>[\\w-]*))?$"
    }
  ]
}
